{
  "name": "Review Analyzer",
  "version": "1.0.0",
  "description": "Scrape and analyze marketplace reviews",
  "manifest_version": 3,
  "permissions": ["activeTab", "scripting", "downloads"],
  "host_permissions": ["https://shopee.co.id/*", "https://tokopedia.com/*"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
